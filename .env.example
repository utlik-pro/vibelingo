# ============================================
# Stripe Configuration
# Get keys from: https://dashboard.stripe.com/apikeys
# ============================================

# Secret key (starts with sk_test_ for test mode)
STRIPE_SECRET_KEY=sk_test_...

# Publishable key (starts with pk_test_ for test mode)
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret (starts with whsec_)
# Create webhook at: https://dashboard.stripe.com/webhooks
# Endpoint URL: https://your-domain.com/api/webhook
# Events to listen: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Stripe Products Setup
# Create at: https://dashboard.stripe.com/products
# ============================================
#
# 1. Product: "VibeLingo PRO Monthly"
#    - Price: 299 RUB / month (recurring)
#    - Copy price ID -> STRIPE_PRICE_PRO_MONTHLY
#
# 2. Product: "VibeLingo PRO Yearly"
#    - Price: 2390 RUB / year (recurring)
#    - Copy price ID -> STRIPE_PRICE_PRO_YEARLY
#
# Then update these IDs in src/components/payment-screen.tsx

STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Server port (optional, default 3001)
PORT=3001

# ============================================
# Supabase (optional - app works with localStorage without it)
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ============================================
# Telegram Bot
# Create bot via @BotFather: https://t.me/BotFather
# ============================================
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
WEBAPP_URL=https://your-domain.com
